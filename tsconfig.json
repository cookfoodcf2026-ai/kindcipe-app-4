{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "skipLibCheck": true,
    "paths": {
      "@/*": [
        "./*"
      ],
      "@shared/*": [
        "../kindcipe-backend/shared/*"
      ],
      "@shared/const": [
        "../kindcipe-backend/shared/const"
      ],
      "@shared/_core/errors": [
        "../kindcipe-backend/shared/_core/errors"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
